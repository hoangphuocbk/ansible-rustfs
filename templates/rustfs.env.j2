# {{ ansible_managed }}
# RustFS server environment file - sourced by the systemd unit.
# This file MUST be identical across every node in the deployment.

# Volumes / topology using {x...y} expansion notation.
RUSTFS_VOLUMES="{{ rustfs_volumes | join(' ') }}"

# S3 API listen address.
RUSTFS_ADDRESS="{{ rustfs_address }}"

# Root credentials (keep identical on every node).
RUSTFS_ACCESS_KEY={{ rustfs_access_key }}
RUSTFS_SECRET_KEY={{ rustfs_secret_key }}

{% if rustfs_console_enable %}
# Built-in web console.
RUSTFS_CONSOLE_ENABLE=true
RUSTFS_CONSOLE_ADDRESS="{{ rustfs_console_address }}"
{% endif %}

# Logging.
RUST_LOG={{ rustfs_log_level }}
RUSTFS_OBS_LOG_DIRECTORY="{{ rustfs_log_dir }}/"
{% if rustfs_env_extra | length > 0 %}

# Extra options.
{% for env in rustfs_env_extra %}
{{ env }}
{% endfor %}
{% endif %}
